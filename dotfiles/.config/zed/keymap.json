[
  {
    "context": "Editor || Modal || Pane || Picker || ProjectPanel || OutlinePanel || Search || Terminal || TitleBar || Workspace",
    "bindings": {
      "alt-shift-\\": "workspace::ToggleBottomDock",
      "alt-shift-f": "workspace::ToggleLeftDock",
      "ctrl-alt-/": "workspace::ToggleBottomDock",
      "ctrl-alt-\\": "workspace::ToggleLeftDock",
      "ctrl-j": null,
      "ctrl-q": null,
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-shift-w": null,
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-w": "pane::CloseActiveItem",
      "ctrl-shift-c": "editor::Copy",
      "ctrl-shift-v": "editor::Paste",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "shift-r": "project_panel::Rename",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-alt-/": "workspace::ToggleBottomDock",
      "ctrl-alt-\\": "workspace::ToggleLeftDock",
      "ctrl-alt-t": "workspace::NewTerminal",
      "ctrl-alt-w": "pane::CloseActiveItem",
      "ctrl-j": null,
      "ctrl-q": null,
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-shift-w": null,
    },
  },
]
